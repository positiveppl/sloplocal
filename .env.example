# Copy to .env and fill in from your Supabase project settings.
# If these are missing, the app runs in DEMO MODE with seed data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only. Required by Cloudflare Pages Functions for API key auth.
# Never expose this in browser/client code.
SUPABASE_SERVICE_ROLE_KEY=

# Optional server-side screenshot capture on admin approval.
# Uses Microlink's free endpoint, no API key required.
SLOP_SCREENSHOT_BUCKET=screenshots
